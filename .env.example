# Token from @BotFather
BOT_TOKEN=8908300767:AAGU03GsTJWcbNsQGfCrgiSCc-chqgqnS8U

# Port the Express server listens on locally (put a reverse proxy in front of it)
PORT=3000

# Path where SQLite stores its file
DB_PATH=./data/bot.db

# --- Webhook settings ---

# A long, random, unguessable string used as part of the webhook URL path,
# e.g. https://yourdomain.com/webhook/<WEBHOOK_PATH_SECRET>
# Generate one with: openssl rand -hex 24
WEBHOOK_PATH_SECRET=unguessablepathforgames

# Public HTTPS URL of your server (no trailing slash), used by
# scripts/set-webhook.js to tell Telegram where to send updates.
PUBLIC_URL=https://yourdomain.com

# Optional but recommended: Telegram will send this back in the
# X-Telegram-Bot-Api-Secret-Token header on every webhook request, and the
# server rejects requests that don't match it.
# Generate one with: openssl rand -hex 24
WEBHOOK_SECRET_TOKEN=unguessablepathforsecret
